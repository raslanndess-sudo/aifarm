# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# database
/data/

# agent team runtime (live chat resets on start, panes.env generated per session)
/.claude/agents/chat.md
/.claude/agents/panes.env
/.claude/scheduled_tasks.lock
/.claude/settings.local.json

# local skills
/.ui-ux-skill/

# working-directory experiment artifacts (Higgsfield image/video tests)
/balloon*
/kitten*
/hg_screenshot*.png
/structure.txt

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
